{
  "manifest_version": 3,
  "name": "整理贴文工具",
  "description": "整理贴文工具",
  "version": "1.1.4",
  "author": "Raz1ner",
  "action": {
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  },
  "background" : {
    "service_worker": "js/background.js"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "declarativeNetRequest"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ]
}
